# Supabase Configuration
# Get your credentials from: https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry Error Monitoring (Production Only - Optional)
# Get DSN from: https://sentry.io/signup/ → Create React Native project
# Note: Sentry is disabled in development (__DEV__ = true)
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
