{
  "name": "halterofit-monorepo",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "dev:mobile": "pnpm --filter @halterofit/mobile start",
    "dev:web": "pnpm --filter @halterofit/web dev",
    "test:mobile": "pnpm --filter @halterofit/mobile test",
    "test:web": "pnpm --filter @halterofit/web test",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{json,md,css,yml,yaml}": [
      "pnpm exec prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.7.4",
    "turbo": "latest"
  }
}
