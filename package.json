{
  "name": "halterofit-monorepo",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/mobile/**/*.{ts,tsx}": ["pnpm exec eslint --fix", "pnpm exec prettier --write"],
    "apps/web/**/*.{ts,tsx}": ["pnpm exec eslint --fix", "pnpm exec prettier --write"],
    "**/*.{json,md,css,yml,yaml}": ["pnpm exec prettier --write"]
  },
  "devDependencies": {
    "turbo": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4"
  }
}
