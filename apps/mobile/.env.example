# Expo Mobile App — Environment Variables
# Copy this file to .env and fill in your values
# These are loaded at build time by Expo (EXPO_PUBLIC_* prefix required)

# Supabase Configuration (Required)
# Get your credentials from: https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NOTE: PUBLISHABLE_KEY is the new Supabase name, ANON_KEY is the legacy alias.
# Both must be set to the same value. Code reads ANON_KEY.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# API Configuration (Planned — not yet used by mobile app)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Sentry Error Monitoring (Optional — production only)
# Disabled in development (__DEV__ = true)
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
